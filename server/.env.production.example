# ResearchIQ backend production environment example
# Copy to server/.env on the VPS and replace placeholder values.

PORT=3001
DATA_DIR=/opt/orcid-tracker-api/data
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret

# LLM provider mode:
#   gemini     -> Gemini only
#   openrouter -> OpenRouter only
#   auto       -> prefer OpenRouter when OPENROUTER_API_KEY is set, otherwise Gemini
LLM_PROVIDER=openrouter

# Gemini configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter configuration
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx
OPENROUTER_MODEL=
OPENROUTER_CHAT_MODEL=
OPENROUTER_REPORT_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter free-model auto-discovery
OPENROUTER_AUTO_DISCOVERY=true
OPENROUTER_DISCOVERY_URL=https://shir-man.com/api/free-llm/top-models
OPENROUTER_DISCOVERY_TTL_MS=1800000
OPENROUTER_DISCOVERY_TIMEOUT_MS=4000

# Optional OpenRouter attribution headers
OPENROUTER_HTTP_REFERER=https://orcid-yourtenant.szabolotnii.site
OPENROUTER_APP_TITLE=ResearchIQ

# Scopus (Elsevier) — domain-locked API key.
# Register the key at https://dev.elsevier.com/ and bind it to your tenant URL.
# SCOPUS_REFERER must match the registered Website URL exactly (incl. trailing slash).
SCOPUS_API_KEY=
SCOPUS_REFERER=https://orcid-yourtenant.szabolotnii.site/
